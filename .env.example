# ──────────────────────────────────────────────
# Frontend (Vite) — exposed to the browser
# ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key

# ──────────────────────────────────────────────
# Server-side only (webhook server) — NEVER expose to the browser
# ──────────────────────────────────────────────
# Used by server/webhook.js to talk to Supabase with elevated privileges
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Used by server/webhook.js to verify incoming Paystack webhook signatures
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
